<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HLA_NoVRLauncher_Avalonia.App"
             xmlns:local="using:HLA_NoVRLauncher_Avalonia"
             RequestedThemeVariant="Dark">
            

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme/>
        <StyleInclude Source="avares://HLA_NoVRLauncher_Avalonia/Styles/AppStyles.axaml" />
    </Application.Styles>
</Application>