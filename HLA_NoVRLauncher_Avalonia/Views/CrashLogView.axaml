<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:HLA_NoVRLauncher_Avalonia.ViewModels"
    x:Class="HLA_NoVRLauncher_Avalonia.Views.CrashLogView"
    x:DataType="vm:CrashLogViewModel">

    <Grid RowDefinitions="Auto, *, Auto" Margin="20">

        <Grid Grid.Row="0"
              ColumnDefinitions="*, Auto, Auto, Auto"
              Margin="0,0,0,12">

            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="CRASH LOG"
                           Classes="section-title"/>
                <TextBlock Text="{Binding LogStatus}"
                           FontSize="12"
                           Foreground="{StaticResource Brush.TextSecondary}"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                <TextBlock Text="Errors &amp; Warnings only"
                           VerticalAlignment="Center"
                           FontSize="12"/>
                <ToggleSwitch IsChecked="{Binding FilterEnabled}"
                              OnContent=""
                              OffContent=""/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="↻ Refresh"
                    Command="{Binding LoadLogCommand}"
                    Margin="0,0,8,0"
                    VerticalAlignment="Center"/>

            <Button Grid.Column="3"
                    Content="🗑 Clear Log"
                    Command="{Binding ClearLogCommand}"
                    VerticalAlignment="Center"
                    Foreground="White"
                    Background="#8B0000"/>
        </Grid>

        <Border Grid.Row="1"
                Classes="card"
                Padding="0"
                Background="#1E1E1E"
                CornerRadius="4">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding LogLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:LogLine}">
                            <Border IsVisible="{Binding IsVisible}"
                                    Padding="12,3">
                                <TextBlock Text="{Binding Text}"
                                           FontFamily="Consolas, Monospace"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding TextColor}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Log is read from: game/hlvr/console.log in your HLA installation. Launch the game with -condebug to enable logging."
                   FontSize="11"
                   Foreground="{StaticResource Brush.TextSecondary}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>

    </Grid>

</UserControl>