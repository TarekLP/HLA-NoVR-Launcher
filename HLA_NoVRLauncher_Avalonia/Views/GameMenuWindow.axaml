<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HLA_NoVRLauncher_Avalonia.Views.GameMenuWindow"
        Title="Game Menu"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="{x:Null}"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        CanResize="False"
        Width="960"
        Height="600">

    <!--
        TransparencyLevelHint="Transparent" + Background="{x:Null}" is the correct
        combination for a true click-through overlay.

        Background="Transparent" looks the same visually but still captures ALL mouse
        input, blocking the game. Background="{x:Null}" removes the brush entirely,
        which tells Avalonia's hit-testing that empty areas have nothing to click on,
        so mouse events fall through to the game window behind it.
    -->
    <Grid Background="{x:Null}">

        <!-- Coloured indicator box — centred in the overlay.
             Replace this with real menu panels in later steps. -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderBrush="#CF9F13"
                BorderThickness="2"
                CornerRadius="4"
                Background="#CC000000"
                Padding="24 16">

            <StackPanel Spacing="6">

                <TextBlock Text="Game Menu Overlay"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#CF9F13"
                           HorizontalAlignment="Center" />

                <TextBlock Text="Geometry sync test"
                           FontSize="13"
                           Foreground="White"
                           HorizontalAlignment="Center" />

                <TextBlock Text="Seeing this over the game window means positioning works."
                           FontSize="11"
                           Foreground="#AAAAAA"
                           HorizontalAlignment="Center" />

            </StackPanel>

        </Border>

    </Grid>

</Window>
