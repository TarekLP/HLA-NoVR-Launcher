<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HLA_NoVRLauncher_Avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="HLA_NoVRLauncher_Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Half-Life: Alyx - NoVR Launcher"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*, Auto">
        <SplitView Grid.Row="0" 
                   IsPaneOpen="{Binding IsSidebarOpen}" 
                   DisplayMode="CompactInline" 
                   OpenPaneLength="220" 
                   CompactPaneLength="50"
                   PaneBackground="{StaticResource Brush.Surface}">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto, *">
                    <Button Grid.Row="0" 
                            Content="≡" 
                            Command="{Binding ToggleSidebarCommand}"
                            HorizontalAlignment="Left"
                            Width="50" Height="50"
                            Background="Transparent"
                            BorderThickness="0"/>
                    
                    <StackPanel Grid.Row="1" Margin="5" Spacing="5" ClipToBounds="True">
                        <Button Classes="sidebar-btn" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource DashboardIconData}" Width="16"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="sidebar-btn" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource SettingsIconData}" Width="16"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="sidebar-btn" HorizontalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource WorkshopIconData}" Width="16"/>
                                <TextBlock Text="Workshop" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <ScrollViewer>
                <StackPanel Margin="25" Spacing="20">
                    <TextBlock Text="Half-Life: Alyx NoVR Mod Launcher" Classes="section-title"/>
                    
                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Game Installation Path" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" 
                                         Text="{Binding Settings.GamePath}" 
                                         Watermark="Path to Half-Life: Alyx"
                                         IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="Browse" Margin="10,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Additional Launch Arguments" FontWeight="Bold"/>
                            <TextBox Text="{Binding Settings.CustomLaunchArgs}" 
                                     Watermark="-console -vconsole"
                                     AcceptsReturn="True" 
                                     Height="80"/>
                        </StackPanel>
                    </Border>

                    <CheckBox Content="Close launcher after game starts" 
                              IsChecked="{Binding Settings.CloseLauncherOnStart}"/>
                </StackPanel>
            </ScrollViewer>
        </SplitView>

        <Border Grid.Row="1" 
                Height="65" 
                Padding="20,0" 
                Background="{StaticResource Brush.SurfaceAlt}" 
                BorderBrush="{StaticResource Brush.Border}" 
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="Status:" FontSize="11" Foreground="{StaticResource Brush.TextSecondary}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <ProgressBar Grid.Column="1" 
                             Margin="40,0" 
                             VerticalAlignment="Center" 
                             IsIndeterminate="{Binding IsBusy}"/>

                <Button Grid.Column="2" 
                        Content="Launch NoVR" 
                        Classes="accent" 
                        Width="180" 
                        Height="40" 
                        FontSize="16" 
                        FontWeight="Black"
                        Command="{Binding LaunchGameCommand}"
                        IsEnabled="{Binding CanLaunch}"/>
            </Grid>
        </Border>
    </Grid>
</Window>