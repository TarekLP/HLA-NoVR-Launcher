<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HLA_NoVRLauncher_Avalonia.ViewModels"
        xmlns:views="using:HLA_NoVRLauncher_Avalonia.Views"
        x:Class="HLA_NoVRLauncher_Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="#050505"
        Title="HLA NoVR Launcher"
        WindowStartupLocation="CenterScreen"
        Width="1280" Height="720">

    <Grid ColumnDefinitions="Auto, *">

        <!-- Sidebar — hidden entirely on the PiracyView so users cannot
             navigate away from it using the sidebar buttons. The Auto column
             collapses to zero width automatically when the Border is hidden. -->
        <Border Grid.Column="0"
                Width="{Binding SidebarWidth}"
                IsVisible="{Binding IsSidebarVisible}"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0"
                ClipToBounds="True">

            <DockPanel>

                <!-- Top: toggle + title -->
                <StackPanel DockPanel.Dock="Top" Spacing="0">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            Padding="12,10">
                        <TextBlock Text="☰"
                                   FontSize="18"
                                   Foreground="{StaticResource Brush.TextSecondary}"/>
                    </Button>

                    <TextBlock Text="Half-Life: Alyx NoVR"
                               IsVisible="{Binding IsSidebarOpen}"
                               FontWeight="Black"
                               FontSize="15"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="16,4,16,16"
                               TextWrapping="Wrap"/>

                    <Separator/>
                </StackPanel>

                <!-- Bottom: version -->
                <StackPanel DockPanel.Dock="Bottom"
                            Margin="8,0,8,12"
                            Spacing="8"
                            IsVisible="{Binding IsSidebarOpen}">
                    <Separator/>
                    <TextBlock Text="{Binding LauncherVersion}"
                               FontSize="11"
                               Foreground="{StaticResource Brush.TextSecondary}"
                               Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Spacing="4" Margin="8,8,8,0">

                    <Button Command="{Binding NavigateMainCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            ToolTip.Tip="Home">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🏠" FontSize="16"/>
                            <TextBlock Text="Home"
                                       IsVisible="{Binding IsSidebarOpen}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateSettingsCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            ToolTip.Tip="Settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="16"/>
                            <TextBlock Text="Settings"
                                       IsVisible="{Binding IsSidebarOpen}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavigateLogCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Padding="10,8"
                            ToolTip.Tip="Crash Log">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="📋" FontSize="16"/>
                            <TextBlock Text="Crash Log"
                                       IsVisible="{Binding IsSidebarOpen}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}">
            <ContentControl.DataTemplates>
                <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                    <views:HomeView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SetupViewModel}">
                    <views:SetupView />
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:CrashLogViewModel}">
                    <views:CrashLogView />
                </DataTemplate>
            </ContentControl.DataTemplates>
        </ContentControl>

    </Grid>
</Window>
